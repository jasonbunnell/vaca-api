# Copy to config/.env and fill in values
# JWT_SECRET=your-secret
# MONGODB_URI=mongodb://localhost:27017/vaca-api

# CORS allowed origins (comma-separated). Default includes localhost and flxvacations.com
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://flxvacations.com

# Google Geocoding (server-side; node-geocoder — see docs/google-maps-geocoding-setup.md)
# GEOCODER_PROVIDER=google
# GEOCODER_API_KEY=your-server-geocoding-key

# Digital Ocean Spaces (property image uploads)
# Get keys from DO Control Panel > API > Spaces Keys
# SPACES_BUCKET_NAME=flxvaca
# SPACES_REGION=nyc3
# SPACES_ACCESS_KEY_ID=your-access-key
# SPACES_SECRET_ACCESS_KEY=your-secret-key

#
